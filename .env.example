# Database
# These POSTGRES_* values are read by docker-compose.yml to provision the
# local dev Postgres container — pick your own values, then keep DATABASE_URL
# below in sync with them (same user/password/db name, port 5433).
POSTGRES_DB="quizify"
POSTGRES_USER="quizify"
POSTGRES_PASSWORD="change-me-to-a-local-dev-password"

DATABASE_URL="postgresql://quizify:change-me-to-a-local-dev-password@localhost:5433/quizify"

# Auth
JWT_SECRET="change-me-to-a-random-64-char-secret-in-production"

# Secret key required to sign up as a HOST. Set this to your own value.
# If left unset, host signup is disabled.
HOST_SIGNUP_KEY="change-me-to-your-own-host-key"

# Server
PORT=3001

# Client (used by Next.js — must be prefixed NEXT_PUBLIC_)
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"
