# Dependency directories
node_modules/
jspm_packages/
web_modules/

# Next.js build outputs and dev caches
.next/
out/
.docusaurus/

# Hono / Express / General build outputs
dist/
build/
bin/
obj/

# Local environment variables and secrets (NEVER commit these!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
*.env

# Keep .env.example for team collaboration/setup reference
!.env.example

# Database / SQLite / Local storage
*.db
*.db-journal
*.sqlite
*.sqlite-journal
uploads/
downloads/

# Prisma specific
# Note: Keep migrations in Git to sync schemas across environments,
# but local dev databases and SQLite files should be ignored.
# prisma/migrations/ # Uncomment only if you explicitly want to ignore migration histories

# Debugging and logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-debug.log*
*.log

# Diagnostic reports (Crashed servers/Node process)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# OS metadata
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDEs and Editors
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.elasticbeanstalk/

# Testing
coverage/
.nyc_output/
.jest/

# TypeScript incremental build cache
*.tsbuildinfo

# Stray Windows redirect artifact (e.g. `cmd > nul` run under a POSIX shell)
nul

